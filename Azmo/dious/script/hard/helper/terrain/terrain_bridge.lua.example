-- Example unsynced Lua sender for Azmo terrain hints.
-- Send once after game start or when map analysis completes.

local function SendTerrainHint(teamID)
  -- Percent scales: 100 = neutral, <100 tighter spread, >100 wider spread
  local buildPct = 92
  local pathPct = 88
  local allyZone = 704
  local waterMap = 0

  local msg = string.format(
    "TERRAIN_HINT:build_pct=%d;path_pct=%d;ally_zone=%d;water_map=%d",
    buildPct, pathPct, allyZone, waterMap
  )
  Spring.SendSkirmishAIMessage(teamID, msg)
end

-- Example usage:
-- SendTerrainHint(Spring.GetMyTeamID())
